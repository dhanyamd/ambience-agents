# --- Event source (the "senses") ---
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
PRODUCT_ID=BTC-USD

# --- Kafka (the "nervous system") ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=crypto.trades

# --- The two-stage funnel ---
# Stage 1 windows trades into fixed time buckets, then runs cheap math.
WINDOW_SECONDS=10
# Stage 1 thresholds — a window must trip ONE of these to reach the LLM.
MIN_TRADES=15                 # ignore thin/illiquid windows
PRICE_MOVE_PCT_THRESHOLD=0.15 # abs % price move within the window
IMBALANCE_THRESHOLD=0.65      # abs buy/sell volume imbalance (0..1)

# --- The brain (local LLM via Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Escalation path (notify only — this agent never trades) ---
# Leave Telegram blank to print notifications to the terminal instead.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
